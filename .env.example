# MCA V3 portal credentials
# User ID is CIN/LLPIN/FCRN for Company/LLP, or email for other user categories
MCA_USER_ID=
MCA_PASSWORD=

# Headed by default for credential entry / OTP / DSC handoff. Set to "true" only for non-interactive runs.
HEADLESS=false

# Slow down each action by N ms — useful while developing to watch the flow
SLOW_MO_MS=0

# Where to persist a logged-in session so we don't re-login every run
STORAGE_STATE_PATH=./storage-state.json

# Vision captcha solver via OpenRouter (Gemini by default). If unset, captcha falls back to manual entry.
OPENROUTER_API_KEY=
# Override the vision model (default: google/gemini-2.5-flash)
# Other good options: google/gemini-2.0-flash-001, google/gemini-2.5-pro
OPENROUTER_MODEL=google/gemini-2.5-flash
# OpenRouter ranking metadata (optional)
OPENROUTER_REFERER=https://registerkaro.in
OPENROUTER_TITLE=mca-filing-service captcha solver
