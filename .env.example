# mca-filing-service environment configuration.
# Copy to .env and edit. Used by both `npm run serve` (dev) and docker compose.

# ── Server ─────────────────────────────────────────────────────────────────
MCA_FILING_PORT=8090
MCA_FILING_ARTIFACT_DIR=./.artifacts/runs

# ── Concurrency ───────────────────────────────────────────────────────────
# Max simultaneous browser-driven filings. Each Chromium instance uses
# ~350 MB RAM + ~5-10% of one vCPU. Tune to the VPS.
MAX_CONCURRENT_JOBS=5

# ── Admin dashboard ───────────────────────────────────────────────────────
# Gates /admin and /admin/api/jobs. Long random string recommended.
# When unset, the dashboard is open to anyone who can reach the worker (dev only).
ADMIN_TOKEN=changeme

# ── Playwright ────────────────────────────────────────────────────────────
# true in production, false to watch the browser locally
HEADLESS=true
# Optional — slow every interaction for debugging
SLOW_MO_MS=0

# ── Captcha auto-solve (optional, OpenRouter / Gemini) ────────────────────
# When set, MCA captchas in the login flow are auto-solved via vision LLM.
# Without this, captchas fall back to manual handoff in the headed browser.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_REFERER=https://registerkaro.in
OPENROUTER_TITLE=mca-filing-service captcha solver

# ── Shared-session mode (LEGACY, dev-only) ────────────────────────────────
# Per-SPOC login mode (the default for the customer-portal trigger) does NOT need these.
# Only used by `npm run login` to create storage-state.json for dev runs.
MCA_USER_ID=
MCA_PASSWORD=
STORAGE_STATE_PATH=./storage-state.json
